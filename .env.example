# ─────────────────────────────────────────────────────────────────
# ФинНайс — переменные окружения
# Скопируй в .env.local и заполни реальными значениями.
# НИКОГДА не коммить .env.local в git!
# ─────────────────────────────────────────────────────────────────

# ── Telegram Bot ──────────────────────────────────────────────────

# Получить у @BotFather:
#   1. Напиши /newbot
#   2. Придумай имя: "ФинНайс Бот"
#   3. Придумай username: finnice_auth_bot
#   4. BotFather пришлёт токен вида: 7123456789:AAHdqTcvCH1vGWJxfSeofSs0K
TELEGRAM_BOT_TOKEN=

# chat_id группы/чата поддержки (куда приходят коды если у юзера нет chat_id).
# Получить: добавь @userinfobot в группу → он напишет chat_id группы.
# Для личного чата: напиши @userinfobot в ЛС → он пришлёт твой id.
TELEGRAM_SUPPORT_CHAT_ID=

# ── Database (PostgreSQL / Supabase / Neon) ───────────────────────

# Строка подключения к PostgreSQL.
# Supabase: Settings → Database → Connection string → URI mode
# Neon:     Dashboard → Connection Details → Connection String
DATABASE_URL=postgresql://user:password@host:5432/finnice

# ── Next.js / App ─────────────────────────────────────────────────

# Публичный URL сайта (без trailing slash)
NEXT_PUBLIC_APP_URL=https://finnice.ru

# Секрет для подписи сессионных cookie (минимум 32 символа)
# Генерировать: openssl rand -base64 32
SESSION_SECRET=

# Режим: development | production
NODE_ENV=development
